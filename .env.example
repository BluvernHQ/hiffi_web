# Canonical site URL for SEO (Open Graph, sitemap, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://hiffi.com

# Optional: Organization JSON-LD (schema.org) — brand name, logo, social profiles, address, geo.
NEXT_PUBLIC_ORG_NAME=Hiffi
NEXT_PUBLIC_ORG_LEGAL_NAME=
NEXT_PUBLIC_ORG_LOGO=/hiffi_logo.png
# Space- or comma-separated profile URLs (sameAs)
NEXT_PUBLIC_ORG_SAME_AS=https://play.google.com/store/apps/details?id=com.hiffi.app,https://apps.apple.com/us/app/hiffi/id6759672725
NEXT_PUBLIC_ORG_ADDRESS_STREET=
NEXT_PUBLIC_ORG_ADDRESS_LOCALITY=
NEXT_PUBLIC_ORG_ADDRESS_REGION=
NEXT_PUBLIC_ORG_ADDRESS_POSTAL_CODE=
# ISO 3166-1 alpha-2 (e.g. US, IN)
NEXT_PUBLIC_ORG_ADDRESS_COUNTRY=
NEXT_PUBLIC_ORG_GEO_LAT=
NEXT_PUBLIC_ORG_GEO_LNG=

# Optional: Bearer JWT for server-side GET /users/{username} (API docs require auth).
# Without this, profile metadata and JSON-LD still use the @handle from the URL;
# rich snippets improve when the token is set (name, bio, image).
HIFFI_SERVER_READ_BEARER=

# Analytics Configuration
# Microsoft Clarity Analytics ID
NEXT_PUBLIC_CLARITY_ID=your_clarity_id_here

# Google Analytics ID
NEXT_PUBLIC_GA_ID=your_ga_id_here

# Umami (e.g. analytics.superlabs.co) website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id_here
