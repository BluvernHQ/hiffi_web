# Canonical site URL for SEO (Open Graph, sitemap, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://hiffi.com

# Optional: Bearer JWT for server-side GET /users/{username} (API docs require auth).
# Without this, profile metadata and JSON-LD still use the @handle from the URL;
# rich snippets improve when the token is set (name, bio, image).
HIFFI_SERVER_READ_BEARER=

# Environment switch:
# - prod: indexing ON, analytics ON
# - beta/dev: indexing OFF, analytics OFF
NEXT_PUBLIC_ENV=beta

# Load script from {NEXT_PUBLIC_API_URL}/analytics (see lib/config). Set to true when the API serves it.
NEXT_PUBLIC_API_ANALYTICS=

# Ingest key expected by analytics API for event writes.
NEXT_PUBLIC_ANALYTICS_INGEST_KEY=

# App version label sent with analytics events.
NEXT_PUBLIC_APP_VERSION=web-nextjs

# Optional: must match API UTM_POLL_INGEST_KEY when set. Sent as X-Utm-Poll-Ingest-Key on POST /utm/poll from the browser.
# NEXT_PUBLIC_UTM_POLL_INGEST_KEY=
